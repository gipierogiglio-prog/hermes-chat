# Google OAuth - Criar em https://console.cloud.google.com/apis/credentials
# 1. Create project → "APIs & Services" → "OAuth consent screen" (External)
# 2. Add scope: .../auth/userinfo.email, .../auth/userinfo.profile
# 3. Credentials → "Create Credentials" → "OAuth client ID" → "Web application"
# 4. Authorized redirect URI: http://localhost:8000/auth/callback
GOOGLE_CLIENT_ID=seu-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-google-client-secret

# Hermes API Server (já configurado)
HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions
HERMES_API_KEY=hermes-chat-secret-key-2026

# Session secret (gerar com: python3 -c "import secrets; print(secrets.token_hex(32))")
SESSION_SECRET=generate-a-random-secret-here

# Onde salvar os vaults dos grupos (relativo ao obsidian vault)
VAULT_BASE_DIR=/home/gian/obsidian-vault
